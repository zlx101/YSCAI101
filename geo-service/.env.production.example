# Copy this file to GEORank/.env on the production server. Never commit the real file.
DEBUG=false
PUBLIC_BASE_URL=https://geo.yscai101.com
TRUSTED_HOSTS=["geo.yscai101.com","localhost","127.0.0.1","api"]

# Generate distinct random values before deployment.
SECRET_KEY=replace-with-a-long-random-secret
SETTINGS_ENCRYPTION_KEY=replace-with-a-long-random-secret
JWT_SECRET=replace-with-a-long-random-secret

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=georank
POSTGRES_USER=georank
POSTGRES_PASSWORD=replace-with-a-long-random-password

REDIS_HOST=redis
REDIS_PORT=6379
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=companies
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-with-a-long-random-password
MINIO_ENDPOINT=minio:9000
MINIO_USER=replace-with-minio-access-key
MINIO_PASSWORD=replace-with-minio-secret-key

# Use an OpenAI-compatible model provider you control. Leave empty only when
# intentionally running without AI generation capabilities.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4o-mini
ALLOW_PRIVATE_LLM_PROVIDER_URLS=false
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Port values used by docker-compose.yscai101.yml. External Nginx owns TLS.
GEORANK_HTTP_PORT=18080
GEORANK_HTTPS_PORT=18443
GEORANK_SEED_ADMIN_PASSWORD=replace-with-a-long-random-password
